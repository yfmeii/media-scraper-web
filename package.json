{
  "name": "media-scraper-web",
  "version": "1.0.0",
  "description": "🎬 媒体刮削管理工具 - 可视化管理媒体文件",
  "type": "module",
  "private": true,
  "workspaces": [
    "client/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --hot server/server.ts",
    "dev:all": "bunx concurrently -k -n server,web -c blue,green \"bun run --hot server/server.ts\" \"cd client/web && bun run dev -- --host 0.0.0.0\"",
    "build": "bun build server/server.ts --outdir=dist --target=bun",
    "start": "bun run dist/server.js",
    "dev:web": "cd client/web && bun run dev -- --host 0.0.0.0",
    "build:web": "cd client/web && bun run build",
    "dev:weapp": "cd client/weapp && pnpm dev",
    "dev:weapp:open": "cd client/weapp && pnpm dev:open",
    "build:weapp": "cd client/weapp && pnpm build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "quality:check": "sentrux check . && sentrux gate .",
    "quality:baseline": "sentrux gate --save ."
  },
  "dependencies": {
    "@media-scraper/shared": "workspace:*",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0"
  }
}
