    "postcss": "^8.5.8",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite-plugin-static-copy": "^3.3.0",
    "vue-tsc": "^3.2.6",
